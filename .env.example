# Frontend Environment Variables
# Local defaults use relative paths so the same config works with Vite dev
# and the Docker nginx gateway. For deployment, override these with your
# public backend URLs in your hosting provider.

VITE_API_URL=/api
VITE_AI_URL=/ai
VITE_WS_URL=/ws/chat
VITE_CHAT_URL=/ws/chat
VITE_NOTIFICATIONS_WS_URL=/ws/notifications
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
